# Workspace meta
# Forks live in DeusExe/ and render11/ — they have their own .git histories,
# their own .gitignore. Don't track them from this workspace either.
DeusExe/
render11/

# SDK content — downloaded fresh per developer machine via setup.ps1.
# Square Enix IP, never committed.
_sdk_cache/
_sdk_extract/
games/

# Local reference copies of UT469 headers (used at patch-development
# time to crib modernization patterns, then thrown away)
_ut469_ref/

# Build outputs
dist/

# Workspace-local PSGallery modules (installed by scripts/install-tools.ps1)
.tools/

# Coverage report from scripts/test.ps1 -Coverage
coverage.xml

# OS noise
Thumbs.db
.DS_Store
